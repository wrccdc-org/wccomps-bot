# Integration Test Configuration
# Copy this file to .env.test and fill in real credentials for testing
# These credentials should be for NON-PRODUCTION test accounts only

# Discord Test Credentials
TEST_DISCORD_USER_TOKEN=your_test_user_discord_token_here
TEST_DISCORD_USERNAME=testuser#1234

# Authentik Test Credentials
TEST_AUTHENTIK_USERNAME=test_user@example.com
TEST_AUTHENTIK_PASSWORD=your_test_user_password_here
TEST_AUTHENTIK_API_TOKEN=your_authentik_api_token_here

# Test Configuration
TEST_TEAM_ID=50
TEST_GUILD_ID=525435725123158026
TEST_TICKET_CATEGORY_ID=your_test_category_id_here

# Test Database (Docker)
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_NAME=wccomps_test
TEST_DB_USER=test_user
TEST_DB_PASSWORD=test_password

# Base URL for integration tests
TEST_BASE_URL=http://localhost:8000

# Authentik URLs (same as production for real API testing)
AUTHENTIK_URL=https://auth.wccomps.org
AUTHENTIK_OIDC_URL=https://auth.wccomps.org/application/o/discord-bot/

# Authentik OAuth Credentials (required for browser tests with authentication)
AUTHENTIK_CLIENT_ID=your_authentik_oauth_client_id_here
AUTHENTIK_SECRET=your_authentik_oauth_client_secret_here
