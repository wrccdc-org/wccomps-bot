# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=525435725123158026  # Competition guild ID
DISCORD_LOG_CHANNEL_ID=your_ops_log_channel_id
# Webhook for 500 error alerts (create in Discord channel settings > Integrations > Webhooks)
DISCORD_ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_TICKET_QUEUE_CHANNEL_ID=1429147071562252360
DISCORD_ANNOUNCEMENT_CHANNEL_ID=1208127199622860881
BLUETEAM_ROLE_ID=525444104763736075
# Authentik group to Discord role mappings
BLACKTEAM_ROLE_ID=779192640540639263
WHITETEAM_ROLE_ID=647838503505362957
ORANGETEAM_ROLE_ID=647878925040615446
REDTEAM_ROLE_ID=546490269693116437
GOLDTEAM_ROLE_ID=1435254879235997897

# Multi-guild configuration for role synchronization
# VOLUNTEER_GUILD_ID is the volunteer Discord server where roles originate
# DISCORD_GUILD_ID (above) is the competition server where roles are synced to
VOLUNTEER_GUILD_ID=404855247857778697

# Authentik OAuth Configuration
AUTHENTIK_URL=https://auth.wccomps.org
AUTHENTIK_OIDC_URL=https://auth.wccomps.org/application/o/discord-bot/
AUTHENTIK_CLIENT_ID=your_oauth_client_id
AUTHENTIK_SECRET=your_oauth_client_secret
AUTHENTIK_TOKEN=your_authentik_api_token
# Note: All permissions controlled via Authentik groups:
# - WCComps_BlueTeam01-50: Team assignment
# - WCComps_Discord_Admin: Full admin access
# - WCComps_Ticketing_Admin: Ticket management
# - WCComps_Ticketing_Support: Ticket support

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=wccomps
DB_USER=wccomps
DB_PASSWORD=your_secure_password_here

# Django Configuration
DJANGO_SECRET_KEY=your_random_secret_key_here
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,bot.wccomps.org
BASE_URL=https://bot.wccomps.org

# Web Server Configuration
WEB_PORT=8000
# Gunicorn workers (default: 4, max recommended: 10 to stay under 50 DB connection limit)
# Each worker uses ~2-3 database connections with connection pooling enabled
GUNICORN_WORKERS=4

# Quotient Scoring Engine Integration
QUOTIENT_API_URL=https://scoring.wccomps.org
QUOTIENT_USERNAME=wccomps_admin
QUOTIENT_PASSWORD=your_quotient_password_here

# Email Configuration (for team packet distribution)
# Email backend: django.core.mail.backends.smtp.EmailBackend (production) or
#                django.core.mail.backends.console.EmailBackend (development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=noreply@wccomps.org
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@wccomps.org
