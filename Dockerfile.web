FROM python:3.13-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy project files
COPY pyproject.toml .
COPY uv.lock* .

# Install dependencies using uv
RUN uv sync --frozen --no-dev

# Copy entrypoint script first
COPY web/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Copy web application code
COPY web/ ./web/

# Create static files directory
RUN mkdir -p /app/web/staticfiles

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV DJANGO_SETTINGS_MODULE=wccomps.settings

WORKDIR /app/web

ENTRYPOINT ["/entrypoint.sh"]
# Use environment variable for workers (default 4, max recommended: 10 to stay under 50 connection limit)
CMD ["sh", "-c", "uv run --no-sync gunicorn wccomps.wsgi:application --bind 0.0.0.0:8000 --workers ${GUNICORN_WORKERS:-4} --timeout 300 --access-logfile - --error-logfile - --log-level info"]
